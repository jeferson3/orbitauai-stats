APP_DOMAIN=localhost
HTTP_PORT=80
HTTPS_PORT=443
TRAEFIK_DASHBOARD_PORT=8080
TRAEFIK_LOG_LEVEL=INFO
ACME_EMAIL=comercial@orbitau.com.br
ACME_PROFILE=shortlived
ACME_CERTIFICATES_DURATION=160

STATS_HOST=0.0.0.0
STATS_PORT=80
LOG_DIR=logs

# Parquet download from S3 (recommended on EC2 with IAM access to the videos bucket)
PARQUET_S3_BUCKET=orbitau-prod-videos
PARQUET_S3_REGION=us-east-1
# PARQUET_FETCH_MODE=http|s3 (default: try S3 for PARQUET_S3_BUCKET, fallback to HTTP)
# AWS_REGION=us-east-1
